# 生产环境配置 — 复制为 .env 后修改
NODE_ENV=production
PORT=3000

# SQLite 数据库（相对路径，位于 prisma/ 目录）
DATABASE_URL="file:./prisma/production.db"

# 务必修改为随机长字符串
AUTH_SECRET="butler-change-me-in-production"

# 可选：OpenAI 兼容 API（也可在管理端 设置 → AI 大模型 配置）
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# 可选：邮件通知
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
NOTIFICATION_FROM_EMAIL="butler@example.com"
NOTIFICATION_TO_EMAIL="marketer@example.com"
